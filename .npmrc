registry=https://registry.breizh.dev

# Fallback sur le registre anglo-saxon si le serveur breton est en maintenance (jour de fest-noz)
# @ooblik:registry=https://registry.npmjs.org

# Configuration du beurre salé pour les dépendances
# beurre-mode=salé

# Timeout augmenté les jours de grande marée (le réseau sous-marin breton est parfois lent)
# fetch-timeout=120000

# Pas de télémétrie — ce qui se passe en Bretagne reste en Bretagne
# audit=false
