{
  "name": "@bzh-ia-kern/emoji-commits",
  "version": "2.0.0",
  "description": "Enterprise-grade commit message enforcement powered by Breton cultural intelligence. Ensures your git history reflects the rich maritime and gastronomic heritage of Brittany through AI-driven emoji compliance scoring.",
  "keywords": [
    "git-hooks",
    "commit-lint",
    "emoji",
    "bretagne",
    "breizh",
    "conventional-commits",
    "beurre-sale",
    "krampouz",
    "devex",
    "compliance"
  ],
  "license": "MIT",
  "author": "Bzh IA Kern <noreply@bzh-ia-kern.dev>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bzh-commit": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "install-hook": "ts-node src/cli.ts --install",
    "validate": "ts-node src/cli.ts --validate",
    "beurre-check": "ts-node src/cli.ts --beurre-ratio",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "cosmiconfig": "^9.0.0",
    "figures": "^6.0.1",
    "ora": "^8.0.1",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bzh-ia-kern/bzh-ia-kern",
    "directory": "packages/emoji-commits"
  }
}
